  <folder name="Motivation" id="id-b14469d7f1314a449e91fc386a1e684d" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da HarvestPro" id="id-12ec93e247664181a9bf3e0324d1dd0a"/>
    <element xsi:type="archimate:Driver" name="Melhorar a produtividade e eficiência no processo das plantações" id="id-539e0a1c548c43fe8bb5cd0175f79723"/>
    <element xsi:type="archimate:Value" name="Melhorar controle de pragas. Reduzir a perda na produçao (que atualmente gira em torno dos 30%) devido ao consumo de pragas e perda na qualidade dos produtos" id="id-6c0544bf6f0f4b9594b3530aefeb6f37"/>
    <element xsi:type="archimate:Value" name="Aumentar a qualidade para que as vendas para o exterior aumentem." id="id-d46185683aec448da6d46ccfccfb01b4"/>
    <element xsi:type="archimate:Assessment" name="Todos os dados do terreno e plantas (umidade do solo, nível de nutrientes, temperatura e etc.) seja coletado." id="id-ca58adfd455b4659bcb806a184b5c57e"/>
    <element xsi:type="archimate:Assessment" name="Ter meios de processar os dados recebidos." id="id-13167b5ebec4400e88b423075b1369e2"/>
    <element xsi:type="archimate:Outcome" name="Outcome" id="id-884b408311844624ae46ea30c326f854"/>
    <element xsi:type="archimate:Goal" name="Criar mecanismo de processamento específico para cada tipo de terreno e agricultura" id="id-9cd590eec73547a184a35e45b2df72e1"/>
    <element xsi:type="archimate:Goal" name="Sistematizar registros de tratativas de chamados até a solução" id="id-35b74a60bef14d6e817290cb1adcef4a"/>
    <element xsi:type="archimate:Goal" name="Coletar em tempo real todos os dados de cada centímetro dos equitares" id="id-03aa7dd373e14234b75000117bd52cb6"/>
    <element xsi:type="archimate:Outcome" name="A função deve estar disponível para a empresa em 31/12/23" id="id-d5bb73d332a64c1a90174131173f711c"/>
    <element xsi:type="archimate:Outcome" name="A função precisa estar pronta junto com o produto final (20/10/2023)" id="id-69ec6d1e0c80453ea7a0eff0d5fba4e8"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-b75e746c742e4249be0714d4b57d5348"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-a9db55a0ece84a0ca02c58d4c97a02d5"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-fca612fec94b42379e20d64006fcd4d4"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-0b9a91318861477d9cbc99c6dd191339"/>
    <element xsi:type="archimate:Principle" name="Processar e comparar os dados vindos de métodos distintos" id="id-fe8e28a97c824d8eaf94bd3179825494"/>
    <element xsi:type="archimate:Principle" name="Trabalhar com mais de um algoritmo de Machine Learning" id="id-6a0069c47e3645f5862d83290ec4631f"/>
    <element xsi:type="archimate:Principle" name="Toda função dos analistas de suporte precisa ser registrada (log) até que o chamado seja solucionado" id="id-f96c7a33f0464ff18e0aed96a5501aa0"/>
    <element xsi:type="archimate:Principle" name="Registrar todos os dados" id="id-a211fb893cb54a55bf6bb3cfb3be9d81"/>
    <element xsi:type="archimate:Principle" name="Possuir mais de um método de recebimento dos dados" id="id-dea2005d9186406996c9a1b90756c50c"/>
    <element xsi:type="archimate:Requirement" name="Retornar informações úteis para cada tipo de cultura plantada" id="id-3a5414e1de16465d88db3b1482ba5e41"/>
    <element xsi:type="archimate:Requirement" name="Consultar chamados por protocolo" id="id-880fa1a5168643c8b8293843ab0be737"/>
    <element xsi:type="archimate:Requirement" name="Movimentar chamado para equipe de especialistas" id="id-99589e7a50ba4087b25fcae3eaee3cb2"/>
    <element xsi:type="archimate:Requirement" name="Registrar solução de chamado" id="id-9f3ba01fc655436cbf932d3d39401ed6"/>
    <element xsi:type="archimate:Requirement" name="Gerar nova análise" id="id-079832cc5b474241894933c0bbe65ce3"/>
    <element xsi:type="archimate:Requirement" name="Registrar ações de tratativa" id="id-5b9d4999966f4d62b2d915101812c8ea"/>
    <element xsi:type="archimate:Requirement" name="Consultar chamados pendentes" id="id-2129410312374abb9bb0fe70e9e5bb13"/>
    <element xsi:type="archimate:Requirement" name="Disparar pesquisa de satisfação" id="id-9ac84ae8d6da4c09a7423437b90dd462"/>
    <element xsi:type="archimate:Requirement" name="Consultar feedback" id="id-ec83f6e074c04e5fa36aab4d5785448c"/>
    <element xsi:type="archimate:Requirement" name="Consultar dados" id="id-9fe17b0562124ebba2d12747baa61032"/>
    <element xsi:type="archimate:Requirement" name="Consulta de FAQ" id="id-8bb72a6a12b14baf8d78582b76651121"/>
    <element xsi:type="archimate:Constraint" name="Gerar gráficos e de forma automática" id="id-03925e93fc91427bb7381985ab81930f"/>
    <element xsi:type="archimate:Constraint" name="Guardar análises antigas e tomar decisões a partir delas, levando em conta o clima, época do ano, fatores climáticos (El Nino por exemplo) e etc." id="id-2b69de5ed9dd4796be04d0920107f8ac"/>
    <element xsi:type="archimate:Constraint" name="Essa base deve conter: Descrição do problema (pergunta), sugestão de diagnóstico e solução" id="id-96268ed00b4342119d586a2fa42c880f"/>
    <element xsi:type="archimate:Constraint" name="Guardar dados de ID do atendente de origem, ID da equipe de destino do chamado, data e hora da movimentação" id="id-a58140b4080a43e4b6fbeb803a13151b"/>
    <element xsi:type="archimate:Constraint" name="Informar o número do protocolo para pesquisa e retornar : ID do contrato de suporte, nome do cliente, telefone de contato, email de contato, descrição do problema, ID do atendente, data e hora da abertura do chamado, status" id="id-fb550f27b86b43c88c63964e97f3cb89"/>
    <element xsi:type="archimate:Constraint" name="Pesquisa ordenado por: prioridade, depois pelo número do protocolo, filtrando por tipo de especialidade para solucionar. Mostrar uma lista com protocolo, descrição do problema, data e hora da abertura" id="id-1cf7d84915cb448281b742737a0abc8a"/>
    <element xsi:type="archimate:Constraint" name="Guardar: descrição da ação realizada, ID  do analista responsável, data e hora da ação" id="id-8c0a9b0527c0415b99561b7a6b79b4f4"/>
    <element xsi:type="archimate:Constraint" name="Registrar no chamado: descrição da solução, ID do analista responsável, data e hora, status = solucionado" id="id-eae0d6adc2304dcd985a5f0e277a91f1"/>
    <element xsi:type="archimate:Constraint" name="Incluir mais uma solução na base de FAC, contendo: descrição do problema, descrição do  diagnóstico, descrição da solução, data e hora de catologação" id="id-85d10f2407944be2b2064e46887b4bc5"/>
    <element xsi:type="archimate:Constraint" name="Enviar email de pesquisa para o endereço cadastrado no chamado, contendo o pedido de avaliação com atribuição de uma das notas (nota 0 = não foi atendido; nota = 1 atendido de forma precaria; nota = 2 plenamente atendido; nota = 3 surpreso com o excelente atendimento. Pedir as notas para um protocolo de chamado resolvido" id="id-3ab0b8277928495aa34b9e9faacffde6"/>
    <element xsi:type="archimate:Constraint" name="Permitir a consulta de feedback para um determinado protocolo" id="id-a2790e778b514925a1bba8391dc4bde5"/>
    <element xsi:type="archimate:Constraint" name="Disponibilizar para a API todos os dados obtidos" id="id-3aba224c6d6f479fb5e73938e7dc708e"/>
  </folder>
